generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  MOBILE_MONEY
  BANK_TRANSFER
}

enum PricingTier {
  LOCAL
  SADC
  INTERNATIONAL
}

enum Season {
  PEAK
  HIGH
  LOW
}

enum BookingType {
  TOUR
  ACCOMMODATION
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  nationality   String?
  role          UserRole  @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  bookings Booking[]
  reviews  Review[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model TourCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  image       String?
  tours       Tour[]

  @@map("tour_categories")
}

model Tour {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String   @db.Text
  highlights   String[]
  duration     String
  maxGroupSize Int
  difficulty   String?
  includes     String[]
  excludes     String[]
  images       String[]
  featured     Boolean  @default(false)
  active       Boolean  @default(true)
  categoryId   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category     TourCategory       @relation(fields: [categoryId], references: [id])
  pricing      TourPricing[]
  addOns       TourAddOn[]
  availability TourAvailability[]
  bookings     Booking[]
  reviews      Review[]

  @@map("tours")
}

model TourPricing {
  id     String      @id @default(cuid())
  tourId String
  tier   PricingTier
  season Season
  price  Float

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, tier, season])
  @@map("tour_pricing")
}

model TourAddOn {
  id          String  @id @default(cuid())
  tourId      String
  name        String
  description String?
  price       Float

  tour          Tour           @relation(fields: [tourId], references: [id], onDelete: Cascade)
  bookingAddOns BookingAddOn[]

  @@map("tour_add_ons")
}

model TourAvailability {
  id     String   @id @default(cuid())
  tourId String
  date   DateTime
  slots  Int
  booked Int      @default(0)

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, date])
  @@map("tour_availability")
}

model Accommodation {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  type        String
  address     String?
  amenities   String[]
  images      String[]
  rating      Float?
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roomTypes RoomType[]
  bookings  Booking[]
  reviews   Review[]

  @@map("accommodations")
}

model RoomType {
  id              String   @id @default(cuid())
  accommodationId String
  name            String
  description     String?
  maxOccupancy    Int
  images          String[]

  accommodation Accommodation    @relation(fields: [accommodationId], references: [id], onDelete: Cascade)
  pricing       RoomPricing[]
  availability  RoomAvailability[]
  bookings      Booking[]

  @@map("room_types")
}

model RoomPricing {
  id         String      @id @default(cuid())
  roomTypeId String
  tier       PricingTier
  season     Season
  price      Float

  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, tier, season])
  @@map("room_pricing")
}

model RoomAvailability {
  id         String   @id @default(cuid())
  roomTypeId String
  date       DateTime
  rooms      Int
  booked     Int      @default(0)

  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, date])
  @@map("room_availability")
}

model Booking {
  id              String        @id @default(cuid())
  bookingRef      String        @unique
  userId          String
  type            BookingType
  tourId          String?
  accommodationId String?
  roomTypeId      String?
  status          BookingStatus @default(PENDING)

  // Tour booking fields
  tourDate DateTime?
  guests   Int       @default(1)

  // Accommodation booking fields
  checkIn  DateTime?
  checkOut DateTime?
  rooms    Int?

  // Pricing
  pricingTier PricingTier
  season      Season
  basePrice   Float
  addOnsTotal Float   @default(0)
  totalPrice  Float
  currency    String  @default("USD")

  // Customer info
  customerName    String
  customerEmail   String
  customerPhone   String
  specialRequests String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  tour          Tour?          @relation(fields: [tourId], references: [id])
  accommodation Accommodation? @relation(fields: [accommodationId], references: [id])
  roomType      RoomType?      @relation(fields: [roomTypeId], references: [id])
  addOns        BookingAddOn[]
  payments      Payment[]

  @@map("bookings")
}

model BookingAddOn {
  id        String @id @default(cuid())
  bookingId String
  addOnId   String
  quantity  Int    @default(1)
  price     Float

  booking Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addOn   TourAddOn @relation(fields: [addOnId], references: [id])

  @@map("booking_add_ons")
}

model Payment {
  id              String        @id @default(cuid())
  bookingId       String
  amount          Float
  currency        String
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  flutterwaveRef  String?
  flutterwaveTxId String?
  isDeposit       Boolean       @default(false)
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model Review {
  id              String   @id @default(cuid())
  userId          String
  tourId          String?
  accommodationId String?
  rating          Int
  comment         String   @db.Text
  approved        Boolean  @default(false)
  createdAt       DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id])
  tour          Tour?          @relation(fields: [tourId], references: [id])
  accommodation Accommodation? @relation(fields: [accommodationId], references: [id])

  @@map("reviews")
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("site_settings")
}

model GalleryImage {
  id       String  @id @default(cuid())
  url      String
  caption  String?
  category String?
  order    Int     @default(0)

  @@map("gallery_images")
}
